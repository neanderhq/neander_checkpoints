{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash __SCRIPTS_DIR__/on_stop.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash __SCRIPTS_DIR__/detect_commit.sh 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
